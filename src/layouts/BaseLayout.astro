---
interface Props {
  title: string;
  description?: string;
  keywords?: string;
  canonical?: string;
}
const { title, description = '', keywords = '', canonical = '' } = Astro.props;
---
<!DOCTYPE html>
<html lang="de">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{title}</title>
  {description && <meta name="description" content={description}>}
  {keywords && <meta name="keywords" content={keywords}>}
  {canonical && <link rel="canonical" href={canonical}>}
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
</head>
<body class="bg-[#FAF8F5] text-[#2D2D2D] antialiased font-['Inter',sans-serif]">
  <!-- Navbar -->
  <header class="sticky top-0 z-50 bg-[#FAF8F5] border-b border-[#E8D5B7]">
    <nav class="max-w-7xl mx-auto px-6 h-20 flex items-center justify-between">
      <a href="/" class="text-2xl font-semibold tracking-tight text-[#2C5D3F]">An & Guo</a>
      <div class="flex items-center gap-8">
        <a href="/#produkte" class="text-sm text-[#2D2D2D] hover:text-[#2C5D3F] transition-colors font-medium relative group">
          Produkte
          <span class="absolute -bottom-1 left-0 w-0 h-0.5 bg-[#2C5D3F] transition-all duration-200 group-hover:w-full"></span>
        </a>
        <a href="/ueber-uns" class="text-sm text-[#2D2D2D] hover:text-[#2C5D3F] transition-colors font-medium relative group">
          Über uns
          <span class="absolute -bottom-1 left-0 w-0 h-0.5 bg-[#2C5D3F] transition-all duration-200 group-hover:w-full"></span>
        </a>
        <a href="/ratgeber" class="text-sm text-[#2D2D2D] hover:text-[#2C5D3F] transition-colors font-medium relative group">
          Blog
          <span class="absolute -bottom-1 left-0 w-0 h-0.5 bg-[#2C5D3F] transition-all duration-200 group-hover:w-full"></span>
        </a>
      </div>
    </nav>
  </header>

  <slot />

  <!-- Footer -->
  <footer class="bg-[#E8D5B7] border-t border-[#E0D5C5] py-12">
    <div class="max-w-7xl mx-auto px-6">
      <div class="flex flex-col md:flex-row items-center justify-between gap-6">
        <div>
          <p class="text-xl font-semibold text-[#2C5D3F] mb-1">An & Guo</p>
          <p class="text-sm text-[#2D2D2D]">Qualität aus Deutschland.</p>
        </div>
        <div class="flex items-center gap-6 text-sm text-[#2D2D2D]">
          <a href="/ueber-uns" class="hover:text-[#2C5D3F] transition-colors">Über uns</a>
          <a href="/versand" class="hover:text-[#2C5D3F] transition-colors">Versand & Retoure</a>
          <a href="/kontakt" class="hover:text-[#2C5D3F] transition-colors">Kontakt</a>
          <a href="/ratgeber" class="hover:text-[#2C5D3F] transition-colors">Blog</a>
        </div>
      </div>
      <div class="mt-8 pt-8 border-t border-[#E0D5C5] text-center">
        <p class="text-sm text-[#2D2D2D]">© 2026 An & Guo. Alle Rechte vorbehalten.</p>
      </div>
    </div>
  </footer>
</body>
</html>
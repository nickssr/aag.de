---
interface Props {
  title: string;
  description?: string;
  keywords?: string;
  canonical?: string;
}
const { title, description = '', keywords = '', canonical = '' } = Astro.props;
---
<!DOCTYPE html>
<html lang="de">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{title}</title>
  {description && <meta name="description" content={description}>}
  {keywords && <meta name="keywords" content={keywords}>}
  {canonical && <link rel="canonical" href={canonical}>}
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
</head>
<body class="bg-white text-[#1a1a1a] antialiased font-['Inter',sans-serif]">
  <header class="sticky top-0 z-50 bg-white/95 backdrop-blur-sm border-b border-gray-100">
    <nav class="max-w-7xl mx-auto px-6 h-20 flex items-center justify-between">
      <a href="/" class="text-2xl font-semibold tracking-tight text-[#1a1a1a]">An & Guo</a>
      <div class="flex items-center gap-8">
        <a href="/#produkte" class="text-sm text-gray-600 hover:text-[#1a1a1a] transition-colors font-medium">Produkte</a>
        <a href="/ueber-uns" class="text-sm text-gray-600 hover:text-[#1a1a1a] transition-colors font-medium">Über uns</a>
        <a href="/ratgeber" class="text-sm text-gray-600 hover:text-[#1a1a1a] transition-colors font-medium">Blog</a>
      </div>
    </nav>
  </header>
  <slot />
  <footer class="bg-gray-50 border-t border-gray-200 py-12">
    <div class="max-w-7xl mx-auto px-6">
      <div class="flex flex-col md:flex-row items-center justify-between gap-6">
        <div>
          <p class="text-xl font-semibold text-[#1a1a1a] mb-1">An & Guo</p>
          <p class="text-sm text-gray-600">Qualität aus Deutschland.</p>
        </div>
        <div class="flex items-center gap-6 text-sm text-gray-600">
          <a href="/ueber-uns" class="hover:text-[#1a1a1a] transition-colors">Über uns</a>
          <a href="/versand" class="hover:text-[#1a1a1a] transition-colors">Versand & Retoure</a>
          <a href="/kontakt" class="hover:text-[#1a1a1a] transition-colors">Kontakt</a>
          <a href="/ratgeber" class="hover:text-[#1a1a1a] transition-colors">Blog</a>
        </div>
      </div>
      <div class="mt-8 pt-8 border-t border-gray-200 text-center">
        <p class="text-sm text-gray-500">© 2026 An & Guo. Alle Rechte vorbehalten.</p>
      </div>
    </div>
  </footer>
</body>
</html>

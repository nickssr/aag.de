---
import BaseLayout from '../layouts/BaseLayout.astro';

const products = [
  {
    name: 'Po Dusche / Intimdusche',
    category: 'Körperpflege',
    price: '€9,90',
    originalPrice: null,
    href: '/intimdusche',
    image: 'img/B0F28TW95V/B0F28TW95V_main.jpg',
    asin: 'B0F28TW95V'
  },
  {
    name: 'Gusseiserne Brotbackform',
    category: 'Küche',
    price: 'ab €45,91',
    originalPrice: '€49,90',
    href: '/gusseisen',
    image: 'img/B0F23MWKYL/B0F23MWKYL_main.jpg',
    asin: 'B0F23MWKYL'
  },
  {
    name: 'Pizza Gleitschieber 12-Zoll',
    category: 'Küche',
    price: '€39,90',
    originalPrice: '€49,90',
    href: '/pizza',
    image: 'img/B0DHZH73KP/B0DHZH73KP_main.jpg',
    asin: 'B0DHZH73KP'
  }
];
---

<BaseLayout
  title="An & Guo | Qualitätsprodukte für Körperpflege und Küche"
  description="An & Guo bietet hochwertige Intimduschen und Küchenprodukte für den täglichen Gebrauch. BPA-frei, hitzebeständig und nachhaltig."
>
  <main>
    <div class="border-b border-gray-100">
      <div class="max-w-7xl mx-auto px-6 py-4">
        <nav class="flex items-center gap-2 text-sm text-gray-500">
          <span class="text-[#1a1a1a]">Startseite</span>
        </nav>
      </div>
    </div>

    <div class="max-w-7xl mx-auto px-6 py-16 md:py-24">
      <h1 class="text-4xl md:text-5xl font-bold text-[#1a1a1a] mb-4">Qualität für<br>Ihr Zuhause</h1>
      <p class="text-xl text-gray-600 mb-12 max-w-2xl">Intime Hygiene und Küchenzubehör – entwickelt für Komfort, designed für Deutschland.</p>

      <div id="produkte" class="grid sm:grid-cols-2 lg:grid-cols-3 gap-8">
        {products.map((product) => (
          <a href={product.href} class="group block bg-white rounded-2xl border border-gray-200 overflow-hidden hover:shadow-lg transition-shadow">
            <div class="aspect-square bg-gray-50 flex items-center justify-center p-8">
              <img src={product.image} alt={product.name} class="w-full h-full object-contain" loading="lazy">
            </div>
            <div class="p-6">
              <p class="text-xs text-gray-500 uppercase tracking-wide mb-1">{product.category}</p>
              <h2 class="text-lg font-semibold text-[#1a1a1a] mb-1">{product.name}</h2>
              <p class="text-xl font-bold text-[#1a1a1a]">
                {product.price}
                {product.originalPrice && <span class="text-sm text-gray-400 line-through ml-2">{product.originalPrice}</span>}
              </p>
            </div>
          </a>
        ))}
      </div>
    </div>

    <div class="bg-gray-50 py-16">
      <div class="max-w-7xl mx-auto px-6">
        <h2 class="text-2xl font-bold text-[#1a1a1a] mb-8 text-center">Warum An & Guo?</h2>
        <div class="grid sm:grid-cols-3 gap-8">
          <div class="text-center">
            <div class="w-12 h-12 bg-white rounded-full flex items-center justify-center mx-auto mb-4 border border-gray-200">
              <svg class="w-6 h-6 text-[#166534]" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
            </div>
            <h3 class="font-semibold text-[#1a1a1a] mb-2">Deutsche Qualität</h3>
            <p class="text-sm text-gray-600">Hochwertige Materialien und strenge Qualitätskontrollen.</p>
          </div>
          <div class="text-center">
            <div class="w-12 h-12 bg-white rounded-full flex items-center justify-center mx-auto mb-4 border border-gray-200">
              <svg class="w-6 h-6 text-[#166534]" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
            </div>
            <h3 class="font-semibold text-[#1a1a1a] mb-2">Schneller Versand</h3>
            <p class="text-sm text-gray-600">Kostenloser Versand ab €20, Lieferung aus Deutschland.</p>
          </div>
          <div class="text-center">
            <div class="w-12 h-12 bg-white rounded-full flex items-center justify-center mx-auto mb-4 border border-gray-200">
              <svg class="w-6 h-6 text-[#166534]" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
            </div>
            <h3 class="font-semibold text-[#1a1a1a] mb-2">30-Tage Rückgabe</h3>
            <p class="text-sm text-gray-600">Kostenlose Rückgabe innerhalb von 30 Tagen.</p>
          </div>
        </div>
      </div>
    </div>
  </main>
</BaseLayout>

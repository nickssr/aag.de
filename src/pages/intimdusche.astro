---
import BaseLayout from '../layouts/BaseLayout.astro';

const variants = [
  { asin: 'B0F28TW95V', color: 'Rot', price: '€9,90', image: 'img/B0F28TW95V/B0F28TW95V_main.jpg' },
  { asin: 'B0F28T7WFL', color: 'Blau', price: '€9,90', image: 'img/B0F28T7WFL/B0F28T7WFL_main.jpg' }
];

const features = [
  'BPA-freier medizinischer Silikon – sicher für den Körper',
  'Ergonomisches Design – liegt gut in der Hand',
  '2 verschiedene Aufsätze für unterschiedliche Bedürfnisse',
  '360ml Füllmenge – ausreichend für eine vollständige Reinigung',
  'Inklusive Tragetasche – ideal für unterwegs',
  'Leicht zu reinigen – einfach mit warmem Wasser abspülen'
];

const faqs = [
  { q: 'Ist die Intimdusche BPA-frei?', a: 'Ja, alle An & Guo Intimduschen sind aus BPA-freiem medizinischen Silikon gefertigt.' },
  { q: 'Kann ich die Intimdusche im Handgepäck mitführen?', a: 'Ja, mit einem Fassungsvermögen von 360ml ist sie für Flugreisen geeignet.' },
  { q: 'Wie reinige ich die Intimdusche?', a: 'Einfach mit warmem Wasser abspülen. Keine aggressiven Reinigungsmittel verwenden.' }
];

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "Product",
  "name": "Po Dusche / Intimdusche kaufen | BPA-frei, tragbar | An & Guo",
  "description": "Po Dusche und Intimdusche aus BPA-freiem medizinischem Silikon. 360ml, ergonomisches Design, inklusive Tragetasche. Ideal für Intimhygiene und unterwegs.",
  "image": "img/B0F28TW95V/B0F28TW95V_main.jpg",
  "brand": { "@type": "Brand", "name": "An & Guo" },
  "offers": {
    "@type": "Offer",
    "price": "9.90",
    "priceCurrency": "EUR",
    "availability": "https://schema.org/InStock",
    "seller": { "@type": "Organization", "name": "An & Guo" }
  }
};
---

<BaseLayout
  title="Po Dusche & Intimdusche kaufen | BPA-frei, tragbar | An & Guo"
  description="Po Dusche und Intimdusche aus BPA-freiem medizinischem Silikon. 360ml, ergonomisches Design, inklusive Tragetasche. Jetzt bei An & Guo."
  canonical="https://aag.de/intimdusche"
>
  <main>
    <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />

    <div class="border-b border-gray-100">
      <div class="max-w-7xl mx-auto px-6 py-4">
        <nav class="flex items-center gap-2 text-sm text-gray-500">
          <a href="/" class="hover:text-[#1a1a1a]">Startseite</a>
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 5l7 7-7 7"/></svg>
          <span class="text-[#1a1a1a]">Po Dusche / Intimdusche</span>
        </nav>
      </div>
    </div>

    <div class="max-w-7xl mx-auto px-6 py-12 md:py-20">
      <div class="grid lg:grid-cols-2 gap-12 lg:gap-16">
        <div class="space-y-4">
          <div id="main-image-container" class="aspect-square bg-white rounded-2xl flex items-center justify-center border border-gray-100">
            <img id="main-image" src={variants[0].image} alt="Po Dusche / Intimdusche" class="w-full h-full object-contain p-8">
          </div>
          <div id="thumbs" class="flex gap-2 flex-wrap">
            {variants.map((v, i) => (
              <button
                onclick={`switchVariant(${i})`}
                class="thumb-btn w-16 h-16 rounded-lg border-2 border-gray-200 overflow-hidden"
                data-index={i}
              >
                <img src={v.image} alt={v.color} class="w-full h-full object-cover">
              </button>
            ))}
          </div>
        </div>

        <div class="lg:py-4">
          <p class="text-xs text-gray-500 uppercase tracking-wide mb-2">Körperpflege</p>
          <h1 class="text-3xl md:text-4xl font-bold text-[#1a1a1a] leading-tight mb-2">Po Dusche / Intimdusche</h1>
          <p class="text-lg text-gray-600 mb-6">BPA-frei, ergonomisch, mit Tragetasche – für eine sanfte und hygienische Intimreinigung</p>

          <div class="mb-6">
            <p class="text-sm text-gray-600 mb-3">Farbe: <span id="color-name" class="font-medium text-[#1a1a1a]">{variants[0].color}</span></p>
            <div id="color-buttons" class="flex gap-3">
              {variants.map((v, i) => (
                <button
                  onclick={`selectVariant(${i})`}
                  class="color-btn w-10 h-10 rounded-full border-2 border-gray-200"
                  style={`background-color: ${v.color === 'Rot' ? '#dc2626' : '#2563eb'}`}
                  title={v.color}
                />
              ))}
            </div>
          </div>

          <div class="py-6 border-y border-gray-100 mb-6">
            <div class="flex items-baseline gap-3">
              <span id="price" class="text-4xl font-bold text-[#1a1a1a]">{variants[0].price}</span>
            </div>
            <p class="text-sm text-gray-500 mt-2">inkl. MwSt.</p>
          </div>

          <a id="buy-btn" href={`https://www.amazon.de/dp/${variants[0].asin}`} target="_blank" rel="noopener" class="flex items-center justify-center gap-3 w-full bg-[#166534] text-white py-4 rounded-xl font-medium hover:opacity-90 transition-opacity">
            Bei Amazon kaufen
          </a>

          <div class="mt-8">
            <h2 class="text-lg font-semibold text-[#1a1a1a] mb-4">Eigenschaften</h2>
            <ul class="space-y-3">
              {features.map(f => (
                <li class="flex items-start gap-3">
                  <svg class="w-5 h-5 text-green-500 mt-0.5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
                  <span class="text-gray-700 text-sm">{f}</span>
                </li>
              ))}
            </ul>
          </div>
        </div>
      </div>
    </div>

    <div class="max-w-7xl mx-auto px-6">
      <div class="mt-12 pt-8 border-t border-gray-200">
        <h2 class="text-lg font-semibold text-[#1a1a1a] mb-4">Produktbeschreibung</h2>
        <div class="text-sm text-gray-700 space-y-3 max-w-4xl">
          <p>Die An & Guo Intimdusche wurde für eine sanfte und gründliche Intimreinigung entwickelt. Das BPA-freie medizinische Silikon ist sicher für den Körper und leicht zu reinigen.</p>
          <p>Das ergonomische Design liegt gut in der Hand und ermöglicht eine einfache Anwendung. Mit 360ml Füllmenge ist sie ausreichend für eine vollständige Reinigung.</p>
          <p>Ideal für zu Hause, auf Reisen oder im Büro – die mitgelieferte Tragetasche macht den Transport diskret und hygienisch.</p>
        </div>
      </div>

      <div class="mt-12 pt-8 border-t border-gray-200">
        <h2 class="text-lg font-semibold text-[#1a1a1a] mb-4">Anwendungsbereiche</h2>
        <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-4 max-w-4xl">
          <div class="bg-gray-50 rounded-xl p-4">
            <p class="font-semibold text-[#1a1a1a] mb-1">Intimhygiene</p>
            <p class="text-sm text-gray-600">Sanfte Reinigung des empfindlichen Intimbereichs.</p>
          </div>
          <div class="bg-gray-50 rounded-xl p-4">
            <p class="font-semibold text-[#1a1a1a] mb-1">Nach dem Sport</p>
            <p class="text-sm text-gray-600">Erfrischende Reinigung nach dem Workout.</p>
          </div>
          <div class="bg-gray-50 rounded-xl p-4">
            <p class="font-semibold text-[#1a1a1a] mb-1">Reise & Büro</p>
            <p class="text-sm text-gray-600">Kompakt und tragbar – überall einsetzbar.</p>
          </div>
          <div class="bg-gray-50 rounded-xl p-4">
            <p class="font-semibold text-[#1a1a1a] mb-1">Medizinische Anwendung</p>
            <p class="text-sm text-gray-600">Empfohlen nach Operationen.</p>
          </div>
        </div>
      </div>

      <div class="mt-12 pt-8 border-t border-gray-200">
        <h2 class="text-lg font-semibold text-[#1a1a1a] mb-4">Häufige Fragen</h2>
        <div class="space-y-3 max-w-3xl">
          {faqs.map(faq => (
            <details class="group border border-gray-200 rounded-xl overflow-hidden">
              <summary class="flex items-center justify-between p-4 cursor-pointer font-medium text-[#1a1a1a] text-sm">
                {faq.q}
                <svg class="w-4 h-4 text-gray-500 group-open:rotate-180 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/></svg>
              </summary>
              <div class="px-4 pb-4 text-gray-600 text-sm">{faq.a}</div>
            </details>
          ))}
        </div>
      </div>

      <div class="mt-12 pt-8 border-t border-gray-200">
        <h2 class="text-lg font-semibold text-[#1a1a1a] mb-6">Technische Daten</h2>
        <div class="bg-white rounded-xl border border-gray-200 overflow-hidden max-w-2xl">
          <dl class="divide-y divide-gray-100">
            {[['Material', 'BPA-freier medizinischer Silikon'], ['Füllmenge', '360ml'], ['Farben', 'Rot, Blau'], ['Gewicht', 'ca. 80g'], ['Inklusive', '2 Aufsätze, Tragetasche'], ['Herkunft', 'Marke: An & Guo']].map(([k, v]) => (
              <div class="grid grid-cols-2 px-6 py-4">
                <dt class="text-sm text-gray-500">{k}</dt>
                <dd class="text-sm text-[#1a1a1a] font-medium">{v}</dd>
              </div>
            ))}
          </dl>
        </div>
      </div>
    </div>
  </main>

  <script define:vars={{ variants }}>
    function selectVariant(index) {
      const v = variants[index];
      document.getElementById('main-image').src = v.image;
      document.getElementById('color-name').textContent = v.color;
      document.getElementById('price').textContent = v.price;
      document.getElementById('buy-btn').href = `https://www.amazon.de/dp/${v.asin}`;
      document.querySelectorAll('.color-btn').forEach((btn, i) => {
        btn.classList.toggle('active', i === index);
      });
    }
    function switchVariant(index) {
      selectVariant(index);
    }
    selectVariant(0);
  </script>
</BaseLayout>

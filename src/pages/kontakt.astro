---
import BaseLayout from '../layouts/BaseLayout.astro';
---
<BaseLayout title="Kontakt | An & Guo" description="Kontaktieren Sie An & Guo für Fragen zu Produkten, Bestellungen oder allgemeine Anfragen.">
  <main>
    <div class="border-b border-gray-100">
      <div class="max-w-7xl mx-auto px-6 py-4">
        <nav class="flex items-center gap-2 text-sm text-gray-500">
          <a href="/" class="hover:text-[#1a1a1a]">Startseite</a>
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 5l7 7-7 7"/></svg>
          <span class="text-[#1a1a1a]">Kontakt</span>
        </nav>
      </div>
    </div>
    <div class="max-w-3xl mx-auto px-6 py-16">
      <h1 class="text-3xl font-bold text-[#1a1a1a] mb-6">Kontakt</h1>
      <div class="prose prose-gray text-gray-700 space-y-4">
        <p>Bei Fragen zu unseren Produkten oder Ihrer Bestellung kontaktieren Sie uns bitte über Amazon. Wir antworten innerhalb von 24 Stunden.</p>
        <p>Für allgemeine Anfragen können Sie uns auch eine E-Mail senden. Wir freuen uns auf Ihre Nachricht.</p>
      </div>
    </div>
  </main>
</BaseLayout>

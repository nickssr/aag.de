---
import BaseLayout from '../layouts/BaseLayout.astro';

const images = [
  '/img/B0DHZH73KP/B0DHZH73KP_main.jpg',
  '/img/B0DHZH73KP/B0DHZH73KP_alt1.jpg',
  '/img/B0DHZH73KP/B0DHZH73KP_alt2.jpg',
  '/img/B0DHZH73KP/B0DHZH73KP_alt3.jpg',
  '/img/B0DHZH73KP/B0DHZH73KP_alt4.jpg',
  '/img/B0DHZH73KP/B0DHZH73KP_alt5.jpg',
  '/img/B0DHZH73KP/B0DHZH73KP_alt6.jpg',
  '/img/B0DHZH73KP/B0DHZH73KP_alt7.jpg',
];

const features = [
  '12-Zoll Pizza Gleitschieber – 30×30cm Arbeitsfläche',
  'Hitzebeständig bis 300°C – ideal fürPizzaöfen und Backofen',
  'Ergonomischer Bambusgriff – stays cool, rutschfest',
  'Integriertes Wiegemesser – Teig einfach und sauber schneiden',
  'Antihaft-Oberfläche – leicht zu reinigen',
  'Abnehmbares Design – platzsparend verstauen'
];

const faqs = [
  { q: 'Für welche Pizzagröße ist der Gleitschieber geeignet?', a: 'Der 12-Zoll (30cm) Gleitschieber eignet sich für die meisten gängigen Pizzagrößen.' },
  { q: 'Kann ich den Gleitschieber im Backofen verwenden?', a: 'Der Gleitschieber ist hitzebeständig bis 300°C und kann im Backofen verwendet werden.' },
  { q: 'Wie reinige ich den Pizza Gleitschieber?', a: 'Einfach mit einem feuchten Tuch abwischen. Der Bambusgriff ist abnehmbar.' }
];

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "Product",
  "name": "Pizza Gleitschieber 12-Zoll kaufen | Antihaft, Bambusgriff | An & Guo",
  "description": "Pizza Gleitschieber 12-Zoll mit Wiegemesser kaufen. 30x30cm, hitzebeständig bis 300°C, ergonomischer Bambusgriff. Antihaft, abnehmbar, leicht zu reinigen.",
  "image": "img/B0DHZH73KP/B0DHZH73KP_main.jpg",
  "brand": { "@type": "Brand", "name": "An & Guo" },
  "offers": {
    "@type": "Offer",
    "price": "39.90",
    "priceCurrency": "EUR",
    "availability": "https://schema.org/InStock",
    "priceValidUntil": "2027-12-31",
    "seller": { "@type": "Organization", "name": "An & Guo" }
  }
};
---

<BaseLayout
  title="Pizza Gleitschieber 12-Zoll kaufen | Antihaft, Bambusgriff | An & Guo"
  description="Pizza Gleitschieber 12-Zoll mit Wiegemesser. 30x30cm, hitzebeständig bis 300°C, ergonomischer Bambusgriff. Antihaft, abnehmbar, leicht zu reinigen."
  canonical="https://aag.de/pizza"
>
  <main>
    <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />

    <div class="border-b border-gray-100">
      <div class="max-w-7xl mx-auto px-6 py-4">
        <nav class="flex items-center gap-2 text-sm text-gray-500">
          <a href="/" class="hover:text-[#1a1a1a]">Startseite</a>
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 5l7 7-7 7"/></svg>
          <span class="text-[#1a1a1a]">Pizza Gleitschieber</span>
        </nav>
      </div>
    </div>

    <div class="max-w-7xl mx-auto px-6 py-12 md:py-20">
      <div class="grid lg:grid-cols-2 gap-12 lg:gap-16">
        <div class="space-y-4">
          <div class="aspect-square bg-white rounded-2xl flex items-center justify-center relative overflow-hidden border border-gray-100">
            <img id="main-image" src={images[0]} alt="Pizza Gleitschieber" class="w-full h-full object-contain p-8">
            <button id="prev-btn" class="absolute left-4 top-1/2 -translate-y-1/2 w-10 h-10 bg-white rounded-full shadow-lg flex items-center justify-center hover:shadow-xl transition-shadow opacity-80 hover:opacity-100">
              <svg class="w-5 h-5 text-gray-700" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/></svg>
            </button>
            <button id="next-btn" class="absolute right-4 top-1/2 -translate-y-1/2 w-10 h-10 bg-white rounded-full shadow-lg flex items-center justify-center hover:shadow-xl transition-shadow opacity-80 hover:opacity-100">
              <svg class="w-5 h-5 text-gray-700" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
            </button>
          </div>
          <div id="thumbs" class="flex gap-2 flex-wrap">
            {images.map((img, i) => (
              <button onclick={`switchImage(${i})`} class={`thumb-btn w-20 h-20 rounded-lg border-2 overflow-hidden transition-all ${i === 0 ? 'border-[#2C5D3F]' : 'border-[#E0D5C5]'}`}>
                <img src={img} alt="" class="w-full h-full object-cover">
              </button>
            ))}
          </div>
        </div>

        <div class="lg:py-4">
          <p class="text-xs text-gray-500 uppercase tracking-wide mb-2">Küche</p>
          <h1 class="text-3xl md:text-4xl font-bold text-[#1a1a1a] leading-tight mb-2">Pizza Gleitschieber, 12-Zoll</h1>
          <p class="text-lg text-gray-600 mb-6">Hitzebeständig bis 300°C, ergonomischer Bambusgriff, mit integriertem Wiegemesser</p>

          <div class="py-6 border-y border-gray-100 mb-6">
            <div class="flex items-baseline gap-3">
              <span class="text-4xl font-bold text-[#1a1a1a]">€39,90</span>
              <span class="text-xl text-gray-400 line-through">€49,90</span>
              <span class="text-sm font-medium text-orange-600 bg-orange-50 px-2 py-1 rounded">-20%</span>
            </div>
            <p class="text-sm text-gray-500 mt-2">inkl. MwSt. · Kostenloser Versand ab €20</p>
          </div>

          <a href="https://www.amazon.de/dp/B0DHZH73KP" target="_blank" rel="noopener" class="flex items-center justify-center gap-3 w-full bg-[#166534] text-white py-4 rounded-xl font-medium hover:opacity-90 transition-opacity">
            Bei Amazon kaufen
          </a>

          <div class="mt-8">
            <h2 class="text-lg font-semibold text-[#1a1a1a] mb-4">Eigenschaften</h2>
            <ul class="space-y-3">
              {features.map(f => (
                <li class="flex items-start gap-3">
                  <svg class="w-5 h-5 text-green-500 mt-0.5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
                  <span class="text-gray-700 text-sm">{f}</span>
                </li>
              ))}
            </ul>
          </div>
        </div>
      </div>
    </div>

    <div class="max-w-7xl mx-auto px-6">
      <div class="mt-12 pt-8 border-t border-gray-200">
        <h2 class="text-lg font-semibold text-[#1a1a1a] mb-4">Produktbeschreibung</h2>
        <div class="text-sm text-gray-700 space-y-3 max-w-4xl">
          <p>Der An & Guo Pizza Gleitschieber macht das Pizza schieben zum Kinderspiel. Die hitzebeständige Oberfläche gleitet mühelos unter Ihre Pizza, während der ergonomische Bambusgriff Ihre Hände vor Hitze schützt.</p>
          <p>Mit dem integrierten Wiegemesser schneiden Sie Ihren Teig sauber und präzise – ohne Krümel. Das abnehmbare Design ermöglicht einfache Reinigung und platzsparende Aufbewahrung.</p>
        </div>
      </div>

      <div class="mt-12 pt-8 border-t border-gray-200">
        <h2 class="text-lg font-semibold text-[#1a1a1a] mb-4">Häufige Fragen</h2>
        <div class="space-y-3 max-w-3xl">
          {faqs.map(faq => (
            <details class="group border border-gray-200 rounded-xl overflow-hidden">
              <summary class="flex items-center justify-between p-4 cursor-pointer font-medium text-[#1a1a1a] text-sm">
                {faq.q}
                <svg class="w-4 h-4 text-gray-500 group-open:rotate-180 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/></svg>
              </summary>
              <div class="px-4 pb-4 text-gray-600 text-sm">{faq.a}</div>
            </details>
          ))}
        </div>
      </div>

      <div class="mt-12 pt-8 border-t border-gray-200">
        <h2 class="text-lg font-semibold text-[#1a1a1a] mb-6">Technische Daten</h2>
        <div class="bg-white rounded-xl border border-gray-200 overflow-hidden max-w-2xl">
          <dl class="divide-y divide-gray-100">
            {[['Größe', '30×30cm (12-Zoll)'], ['Material', 'Aluminium + Bambus'], ['Hitzebeständig', 'Bis 300°C'], ['Griffmaterial', 'Bambus'], ['Integrietes Messer', 'Ja'], ['Gewicht', 'ca. 500g']].map(([k, v]) => (
              <div class="grid grid-cols-2 px-6 py-4">
                <dt class="text-sm text-gray-500">{k}</dt>
                <dd class="text-sm text-[#1a1a1a] font-medium">{v}</dd>
              </div>
            ))}
          </dl>
        </div>
      </div>
    </div>
  </main>

  <script define:vars={{ images }}>
    let currentIndex = 0;
    function switchImage(index) {
      currentIndex = index;
      document.getElementById('main-image').src = images[index];
      document.querySelectorAll('.thumb-btn').forEach((btn, i) => {
        if (i === index) {
          btn.classList.add('border-[#2C5D3F]');
          btn.classList.remove('border-[#E0D5C5]');
        } else {
          btn.classList.remove('border-[#2C5D3F]');
          btn.classList.add('border-[#E0D5C5]');
        }
      });
    }
    function prevImage() {
      switchImage((currentIndex - 1 + images.length) % images.length);
    }
    function nextImage() {
      switchImage((currentIndex + 1) % images.length);
    }
    document.getElementById('prev-btn').addEventListener('click', prevImage);
    document.getElementById('next-btn').addEventListener('click', nextImage);
    switchImage(0);
  </script>
</BaseLayout>
